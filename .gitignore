# ================================
# Sensitive files
# ================================
.env
.env.local
.env.*.local
secrets.json
credentials.json

# ================================
# Data / user sessions
# ================================
backend/data/*
!backend/data/guides/
!backend/data/guides/**

# Keep manual PDFs out of git (car images are allowed)
*.pdf

# ================================
# Python
# ================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
build/
dist/
*.egg-info/
*.egg
.pytest_cache/
.coverage
htmlcov/
*.log

# ================================
# Vector stores (global)
# ================================
vector_store/
*.faiss
*.pkl

# Keep pre-indexed deploy guides tracked
!backend/data/guides/**/vector_store/
!backend/data/guides/**/vector_store/**
!backend/data/guides/**/*.faiss
!backend/data/guides/**/*.pkl

# ================================
# Node / React / Vite
# ================================
node_modules/
frontend/dist/
frontend/build/
.vite/

# ================================
# IDE
# ================================
.vscode/
.idea/
*.swp
*.swo

# ================================
# OS
# ================================
.DS_Store
Thumbs.db

# ================================
# Deploy
# ================================
.vercel

# ================================
# Misc
# ================================
*.bak
*.tmp
*.temp
